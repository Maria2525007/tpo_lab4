<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Stress Test - stload.se.ifmo.ru" enabled="true">
      <stringProp name="TestPlan.comments">Стресс-тестирование выбранной конфигурации.
Цель: найти точку отказа — нагрузку, при которой время отклика превышает 640 мс.
Тест последовательно прогоняет нагрузку: 2, 4, 6, 8, 10, 12, 16, 20, 25, 30 пользователей.
Каждый шаг длится 90 секунд. Результаты сохраняются в results/stress_configN.jtl.
ВАЖНО: перед запуском включи VPN (внутренняя сеть кафедры ИТМО).
ВАЖНО: замени значение CONFIG на номер выбранной конфигурации (1, 2 или 3).</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <!-- Группы запускаются последовательно, чтобы шаги не перекрывались -->
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="TOKEN" elementType="Argument">
            <stringProp name="Argument.name">TOKEN</stringProp>
            <stringProp name="Argument.value">469285053</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="USER" elementType="Argument">
            <stringProp name="Argument.name">USER</stringProp>
            <stringProp name="Argument.value">-2104962546</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">localhost</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="PORT" elementType="Argument">
            <stringProp name="Argument.name">PORT</stringProp>
            <stringProp name="Argument.value">8079</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <!-- Номер выбранной конфигурации: ЗАМЕНИ на 1, 2 или 3 по результатам нагрузочного теста -->
          <elementProp name="CONFIG" elementType="Argument">
            <stringProp name="Argument.name">CONFIG</stringProp>
            <stringProp name="Argument.value">3</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <!-- Продолжительность каждого шага нагрузки: 90 секунд -->
          <elementProp name="STEP_DURATION_SEC" elementType="Argument">
            <stringProp name="Argument.name">STEP_DURATION_SEC</stringProp>
            <stringProp name="Argument.value">90</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <!-- Задержка между запросами: 3000 мс = 20 запр/мин на поток -->
          <elementProp name="REQUEST_DELAY_MS" elementType="Argument">
            <stringProp name="Argument.name">REQUEST_DELAY_MS</stringProp>
            <stringProp name="Argument.value">3000</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- ========== ШАГ 1: 2 пользователя ========== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Step 1 - 2 Users" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">2</stringProp>
